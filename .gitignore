# ==========================================
# Cấu hình .gitignore cho dự án Java Spring Boot & Swing
# Loại bỏ các file rác, file build không cần thiết
# ==========================================

# 1. Các file biên dịch (Compiled class files)
*.class

# 2. Các file đóng gói (Package Files)
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# 3. Thư mục build của Maven
target/
**/target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# 4. Các file cấu hình của IDE (IntelliJ, VSCode, Eclipse)
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# 5. Các file log và dump (Logs and databases)
*.log
*.sqlite
hs_err_pid*
replay_pid*

# 6. Các file rác sinh ra trong quá trình đóng gói (.exe)
jpackage-input/
output-exe/
*.exe
*.msi
*.app
*.dmg
*.pkg

# 7. Các file rác hệ điều hành (OS generated files)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
Thumbs.db

# 8. Một số file rác vô tình tạo ra ở thư mục gốc (nếu có)
/git
/main
